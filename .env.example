TIMELENS_APP_NAME=TimeLens
TIMELENS_ENV=development
TIMELENS_DEBUG=true
TIMELENS_DATABASE_URL=sqlite:///./data/db/timelens.db
TIMELENS_DATA_DIR=./data
TIMELENS_THUMBNAIL_DIR=./data/thumbnails
TIMELENS_CACHE_DIR=./data/cache
TIMELENS_DEFAULT_SCAN_DIR=
TIMELENS_GEOCODER_PROVIDER=nominatim
TIMELENS_GEOCODER_ENABLED=true
TIMELENS_GEOCODER_USER_AGENT=TimeLens/0.1
TIMELENS_GEOCODER_TIMEOUT_SECONDS=8
TIMELENS_HOST=127.0.0.1
TIMELENS_PORT=8000
